# Flask app
SECRET_KEY=change-me

# Phase 4 - device sync worker
DEVICE_ID=rpi5-gate-1
# Use your Railway public URL for the cloud sync service.
# Example: https://your-service-name.up.railway.app
CLOUD_API_BASE_URL=https://your-service-name.up.railway.app
# Use a long random shared secret and set the same value on Railway.
CLOUD_API_KEY=replace-with-long-random-shared-key
SYNC_INTERVAL_SECONDS=60
SYNC_BATCH_SIZE=100
SYNC_HTTP_TIMEOUT_SECONDS=5
SYNC_INCLUDE_FAILED=1

# Cloud API local database path (for cloud_sync_api.py)
# On Railway, prefer a mounted volume path, e.g. /data/cloud_sync.db
CLOUD_SYNC_DB_PATH=cloud_sync.db
